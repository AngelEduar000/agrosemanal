# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://usuario:password@host/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-largo-con-openssl-rand-base64-32"

# Único correo autorizado para entrar a la app
AUTHORIZED_EMAIL="tu-correo@ejemplo.com"

# Resend (magic link y notificaciones)
AUTH_RESEND_KEY="re_xxxxxxxx"
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="AgroSemanal <notificaciones@tudominio.com>"

# Cron (Vercel) — opcional en local
CRON_SECRET="otro-secreto-para-proteger-los-cron"
