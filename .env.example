# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://usuario:password@host/neondb?sslmode=require"

# NextAuth / Auth.js (obligatorio en Vercel)
NEXTAUTH_URL="https://tu-app.vercel.app"
NEXTAUTH_SECRET="genera-un-secreto-largo"
AUTH_SECRET="mismo-valor-que-NEXTAUTH_SECRET"

# Único correo que puede entrar (debe coincidir al solicitar el enlace)
AUTHORIZED_EMAIL="tu-correo@ejemplo.com"

# Resend — OBLIGATORIO para magic link (Auth.js busca AUTH_RESEND_KEY primero)
AUTH_RESEND_KEY="re_xxxxxxxx"
# Misma key para notificaciones automáticas (puede ser la misma variable)
RESEND_API_KEY="re_xxxxxxxx"

# Remitente: en prueba use onboarding@resend.dev (solo envía al email de su cuenta Resend)
EMAIL_FROM="AgroSemanal <onboarding@resend.dev>"

# Cron en Vercel
CRON_SECRET="otro-secreto-aleatorio"
